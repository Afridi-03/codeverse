#include <stdio.h>

int main() {
    int T;
    scanf("%d", &T);

    for (int i = 1; i <= T; i++) {
        int n;
        scanf("%d", &n);

        int original = n;
        int reverse = 0;

        while (n > 0) {
            reverse = reverse * 10 + (n % 10);
            n /= 10;
        }

        if (original == reverse)
            printf("Case %d: Yes\n", i);
        else
            printf("Case %d: No\n", i);
    }

    return 0;
}
